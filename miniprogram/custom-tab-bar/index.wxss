.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid #F3F4F6;
  z-index: 999;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 8rpx 0;
  transition: all 0.2s ease;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  transition: all 0.2s ease;
}

.tab-icon.icon-active {
  width: 54rpx;
  height: 54rpx;
}

.tab-text {
  font-size: 20rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
  transition: all 0.2s ease;
}

.tab-text.text-active {
  color: #FF6B6B;
  font-weight: 600;
  font-size: 22rpx;
}
