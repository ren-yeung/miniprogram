<view class="tab-bar">
  <view 
    class="tab-item {{selected === index ? 'active' : ''}}" 
    wx:for="{{list}}" 
    wx:key="index"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <image 
      class="tab-icon {{selected === index ? 'icon-active' : ''}}" 
      src="{{selected === index ? item.selectedIconPath : item.iconPath}}" 
      mode="aspectFit"
    />
    <text class="tab-text {{selected === index ? 'text-active' : ''}}">{{item.text}}</text>
  </view>
</view>
