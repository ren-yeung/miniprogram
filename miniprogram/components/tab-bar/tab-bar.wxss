/**
 * @file TabBar样式
 * 底部导航栏 - 凸起发布按钮
 */

/* ==================== TabBar容器 ==================== */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  z-index: 1000;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 上边框渐变 */
.tab-bar-border {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(to right, transparent, #E5E7EB 20%, #E5E7EB 80%, transparent);
}

/* ==================== TabBar内容 ==================== */
.tab-bar-content {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 100rpx;
  padding: 0 8rpx;
}

/* ==================== Tab项 ==================== */
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
  transition: all 0.2s ease;
}

.tab-icon-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-icon {
  font-size: 44rpx;
  line-height: 1;
}

.tab-text {
  font-size: 20rpx;
  margin-top: 4rpx;
  color: #9CA3AF;
  transition: color 0.2s ease;
}

/* 激活状态 */
.tab-item.active .tab-icon {
  transform: scale(1.1);
}

.tab-item.active .tab-text {
  color: #FF6B6B;
  font-weight: 600;
}

/* ==================== 消息红点 ==================== */
.message-red-dot {
  position: absolute;
  top: -4rpx;
  right: -8rpx;
  width: 16rpx;
  height: 16rpx;
  background-color: #EF4444;
  border-radius: 50%;
  border: 2rpx solid #ffffff;
}

/* ==================== 特殊发布按钮 ==================== */
.special-tab {
  flex: 0.8;
}

.publish-btn {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B6B, #FF8EC4);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 107, 0.4);
  transform: translateY(-20rpx);
  transition: all 0.2s ease;
}

.publish-btn:active {
  transform: translateY(-20rpx) scale(0.95);
  box-shadow: 0 4rpx 10rpx rgba(255, 107, 107, 0.3);
}

.publish-icon {
  font-size: 48rpx;
  color: #ffffff;
  font-weight: 300;
  line-height: 1;
}
