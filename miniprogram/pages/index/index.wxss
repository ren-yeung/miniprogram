/* 首页样式 - pages/index/index.wxss */

/* ===================== 页面基础 ===================== */

.index-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFF9F5;
}

/* ===================== 自定义导航栏 ===================== */

.nav-bar-container {
  background: #FFF9F5;
  flex-shrink: 0;
  padding-left: 32rpx;
  padding-right: 32rpx;
  padding-bottom: 8rpx;
  margin-top: 20rpx;
}

.nav-bar-title {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.logo {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.logo-icon {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8EC4);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.logo-text {
  font-size: 36rpx;
  font-weight: 400;
  color: #1F2937;
  display: flex;
  align-items: center;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 24rpx 24rpx 0 24rpx;
}

.location {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 0;
  flex-shrink: 0;
}

.location-icon {
  font-size: 24rpx;
}

.location-text {
  font-size: 26rpx;
  color: #1F2937;
  font-weight: 500;
  max-width: 100rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.location-arrow {
  font-size: 18rpx;
  color: #9CA3AF;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #F5F0EB;
  padding: 16rpx 24rpx;
  border-radius: 50rpx;
  max-width: 480rpx;
}

.search-icon {
  font-size: 28rpx;
}

.search-placeholder {
  font-size: 26rpx;
  color: #9CA3AF;
}

.message-btn {
  position: relative;
  padding: 10rpx;
  flex-shrink: 0;
}

.bell-icon {
  font-size: 40rpx;
}

.red-dot {
  position: absolute;
  top: 8rpx;
  right: 6rpx;
  width: 16rpx;
  height: 16rpx;
  background: #FF6B6B;
  border-radius: 50%;
  border: 2rpx solid #ffffff;
}

/* ===================== 主内容区域 ===================== */

.main-content {
  flex: 1;
  height: 0; /* 关键：flex剩余空间 */
}

/* ===================== Banner轮播 ===================== */

.banner-swiper {
  height: 320rpx;
  margin: 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.5));
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.banner-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

.banner-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* ===================== 功能图标 ===================== */

.func-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}

.func-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.func-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.func-name {
  font-size: 22rpx;
  color: #666;
}

/* ===================== 分类标签 ===================== */

.category-scroll {
  white-space: nowrap;
  padding: 0 24rpx;
  margin-bottom: 16rpx;
}

.category-list {
  display: inline-flex;
  gap: 16rpx;
}

.category-item {
  display: inline-block;
  padding: 12rpx 24rpx;
  background: #ffffff;
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #666;
  white-space: nowrap;
}

.category-item.active {
  background: #FF6B6B;
  color: #ffffff;
  font-weight: 500;
}

/* ===================== 内容Tab ===================== */

.content-tabs {
  padding: 0 24rpx;
  margin-bottom: 16rpx;
}

.tabs-row {
  display: flex;
  gap: 32rpx;
  border-bottom: 2rpx solid #F0F0F0;
  padding-bottom: 16rpx;
}

.tab-item {
  font-size: 28rpx;
  color: #9CA3AF;
  position: relative;
}

.tab-item.active {
  color: #222;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: -18rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: #FF6B6B;
  border-radius: 3rpx;
}

/* ===================== 瀑布流 ===================== */

.masonry-container {
  display: flex;
  padding: 0 12rpx;
  gap: 12rpx;
}

.masonry-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.post-card {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.post-image {
  width: 100%;
  display: block;
}

.post-info {
  padding: 16rpx;
}

.post-title {
  font-size: 26rpx;
  color: #222;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.post-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.author-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
}

.author-name {
  flex: 1;
  font-size: 22rpx;
  color: #9CA3AF;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-actions {
  display: flex;
  gap: 16rpx;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.action-icon {
  font-size: 24rpx;
  color: #9CA3AF;
}

.action-icon.liked {
  color: #FF6B6B;
}

.action-count {
  font-size: 22rpx;
  color: #9CA3AF;
}

/* ===================== 底部提示 ===================== */

.bottom-tip {
  text-align: center;
  padding: 32rpx;
  color: #9CA3AF;
  font-size: 24rpx;
}
