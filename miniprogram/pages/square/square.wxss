/* 广场页样式 - pages/square/square.wxss */

/* ===================== 页面基础 ===================== */

.square-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFF9F5;
  position: relative;
}

/* ===================== 自定义导航栏 ===================== */

.nav-bar-container {
  background: #FFF9F5;
  flex-shrink: 0;
  padding-left: 32rpx;
  padding-right: 32rpx;
  padding-bottom: 12rpx;
  margin-top: 20rpx;
}

.nav-bar-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.logo {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.logo-icon {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8EC4);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.logo-text {
  font-size: 36rpx;
  font-weight: 400;
  color: #1F2937;
}

.header-actions {
  display: flex;
  gap: 24rpx;
}

.action-icon {
  font-size: 32rpx;
  padding: 8rpx;
}

/* ===================== Tab导航 ===================== */

.tab-scroll {
  white-space: nowrap;
  margin: 24rpx 24rpx 0 24rpx;
}

.tab-list {
  display: inline-flex;
  gap: 32rpx;
}

.tab-item {
  display: inline-block;
  padding: 12rpx 0;
  font-size: 28rpx;
  color: #9CA3AF;
  position: relative;
}

.tab-item.active {
  color: #222;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: #FF6B6B;
  border-radius: 3rpx;
}

/* ===================== 内容区域 ===================== */

.content {
  flex: 1;
  height: 0;
}

/* ===================== 瀑布流 ===================== */

.masonry-container {
  display: flex;
  padding: 24rpx 12rpx;
  gap: 12rpx;
}

.masonry-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.post-card {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  position: relative;
}

.post-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background: rgba(255, 107, 107, 0.9);
  color: #ffffff;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 50rpx;
  z-index: 1;
}

.post-image {
  width: 100%;
  display: block;
}

.post-info {
  padding: 16rpx;
}

.post-title {
  font-size: 26rpx;
  color: #222;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.post-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.author-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
}

.author-name {
  flex: 1;
  font-size: 22rpx;
  color: #9CA3AF;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-actions {
  display: flex;
  gap: 16rpx;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.action-icon {
  font-size: 24rpx;
  color: #9CA3AF;
}

.action-count {
  font-size: 22rpx;
  color: #9CA3AF;
}

/* ===================== 底部提示 ===================== */

.bottom-tip {
  text-align: center;
  padding: 32rpx;
  color: #9CA3AF;
  font-size: 24rpx;
}

/* ===================== 发布按钮 ===================== */

.publish-btn {
  position: fixed;
  right: 32rpx;
  bottom: 160rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8EC4);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #ffffff;
  font-weight: 300;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.4);
  z-index: 10;
}

/* ===================== 发布面板 ===================== */

.publish-sheet {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.publish-sheet.show {
  opacity: 1;
  visibility: visible;
}

.publish-panel {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.publish-sheet.show .publish-panel {
  transform: translateY(0);
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
}

.close-btn {
  font-size: 32rpx;
  color: #9CA3AF;
  padding: 8rpx;
}

.publish-options {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.publish-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.option-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.option-name {
  font-size: 24rpx;
  color: #666;
}
