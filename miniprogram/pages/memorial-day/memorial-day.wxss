/* 宠物纪念日 - pages/memorial-day/memorial-day.wxss */

/* ===================== 页面基础 ===================== */

.memorial-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFF9F5;
}

/* ===================== 自定义导航栏 ===================== */

.nav-bar-container {
  background: #FFF9F5;
  flex-shrink: 0;
  padding-left: 32rpx;
  padding-right: 32rpx;
  padding-bottom: 12rpx;
  margin-top: 20rpx;
}

.nav-bar-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-left {
  width: 88rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #1F2937;
}

.nav-center {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #1F2937;
}

.nav-right {
  width: 88rpx;
  display: flex;
  justify-content: flex-end;
}

.nav-action {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: 300;
  color: #FF6B6B;
}

/* ===================== 主内容 ===================== */

.content {
  flex: 1;
  height: 0;
}

/* ===================== 倒计时卡片 ===================== */

.countdown-card {
  margin: 24rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8EC4);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
  box-shadow: 0 8rpx 28rpx rgba(255, 107, 107, 0.25);
}

.countdown-bg {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.countdown-emoji {
  font-size: 60rpx;
}

.countdown-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.countdown-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.countdown-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
}

.countdown-days {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  margin-top: 8rpx;
}

.days-number {
  font-size: 56rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 1;
}

.days-unit {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
}

.days-suffix {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-left: 4rpx;
}

.countdown-date {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 4rpx;
}

/* ===================== 空状态 ===================== */

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #9CA3AF;
  text-align: center;
  margin-bottom: 40rpx;
}

.empty-add-btn {
  background: #FF6B6B;
  color: #ffffff;
  font-size: 28rpx;
  padding: 20rpx 48rpx;
  border-radius: 50rpx;
}

/* ===================== 加载状态 ===================== */

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-text {
  font-size: 26rpx;
  color: #9CA3AF;
}

/* ===================== 区块样式 ===================== */

.section {
  padding: 16rpx 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.section-accent {
  width: 8rpx;
  height: 32rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
}

.section-count {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-left: auto;
}

/* ===================== 纪念日卡片 ===================== */

.memorial-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.memorial-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.memorial-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.memorial-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.memorial-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.memorial-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
}

.memorial-badge {
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border-radius: 50rpx;
  white-space: nowrap;
}

.memorial-desc {
  font-size: 22rpx;
  color: #9CA3AF;
}

.memorial-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 2rpx;
}

.memorial-date {
  font-size: 22rpx;
  color: #6B7280;
}

.memorial-divider {
  font-size: 22rpx;
  color: #D1D5DB;
}

.memorial-days {
  font-size: 22rpx;
  color: #FF6B6B;
}

.memorial-arrow {
  font-size: 40rpx;
  color: #D1D5DB;
  flex-shrink: 0;
}

/* ===================== 底部区域 ===================== */

.bottom-area {
  padding: 32rpx 24rpx 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.add-button {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: 100%;
  padding: 24rpx;
  background: #ffffff;
  border: 2rpx dashed #D1D5DB;
  border-radius: 20rpx;
}

.add-icon {
  font-size: 32rpx;
  color: #FF6B6B;
  font-weight: 300;
}

.add-text {
  font-size: 28rpx;
  color: #6B7280;
  font-weight: 500;
}

.bottom-tip {
  font-size: 22rpx;
  color: #D1D5DB;
}
