<!--
  帖子详情页 - pages/post-detail/post-detail.wxml
-->
<view class="detail-page">
  <!-- 导航栏占位 - 与首页对齐 -->
  <view 
    class="nav-bar-placeholder"
    style="padding-top: {{statusBarHeight}}px;"
  >
    <view class="nav-bar-inner" style="height: {{menuButtonHeight}}px;">
      <view class="back-btn" bindtap="onBackTap">‹</view>
      <text class="navbar-title">帖子详情</text>
      <view class="share-btn">📤</view>
    </view>
  </view>

  <scroll-view class="content" scroll-y>
    <!-- 用户信息 -->
    <view class="user-section">
      <image class="user-avatar" src="{{post.user.avatar}}" mode="aspectFill" />
      <view class="user-info">
        <text class="user-name">{{post.user.name}}</text>
        <text class="post-time">{{post.createTime}}</text>
      </view>
      <view class="follow-btn">关注</view>
    </view>

    <!-- 标题 -->
    <text class="post-title">{{post.title}}</text>

    <!-- 图片 -->
    <view class="images-grid">
      <block wx:for="{{post.images}}" wx:key="index">
        <image class="post-image" src="{{item}}" mode="aspectFill" />
      </block>
    </view>

    <!-- 内容 -->
    <text class="post-content">{{post.content}}</text>

    <!-- 标签 -->
    <view class="tags-row">
      <text class="tag">#宠物乐园</text>
      <text class="tag">#游泳</text>
      <text class="tag">#金毛</text>
    </view>

    <!-- 互动栏 -->
    <view class="action-bar">
      <view class="action-item" bindtap="onLikeTap">
        <text class="action-icon {{liked ? 'liked' : ''}}">❤</text>
        <text class="action-count">{{post.likes}}</text>
      </view>
      <view class="action-item">
        <text class="action-icon">💬</text>
        <text class="action-count">{{post.comments}}</text>
      </view>
      <view class="action-item">
        <text class="action-icon">⭐</text>
        <text class="action-count">收藏</text>
      </view>
    </view>

    <!-- 评论区 -->
    <view class="comments-section">
      <text class="comments-title">评论 ({{post.comments}})</text>
      <view class="comment-item">
        <image class="comment-avatar" src="https://i.pravatar.cc/48?img=10" mode="aspectFill" />
        <view class="comment-content">
          <text class="comment-name">旺财主人</text>
          <text class="comment-text">也太可爱了吧！</text>
          <text class="comment-time">1小时前</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 底部输入栏 -->
  <view class="input-bar">
    <input class="input-field" placeholder="说点什么..." />
    <view class="send-btn">发送</view>
  </view>
</view>
