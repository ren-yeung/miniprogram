/* 帖子详情页样式 */

.detail-page {
  height: 100vh;
  background: #FFF9F5;
  display: flex;
  flex-direction: column;
}

.nav-bar-placeholder {
  background: #FFF9F5;
  flex-shrink: 0;
  padding-left: 32rpx;
  padding-right: 32rpx;
  padding-bottom: 8rpx;
  margin-top: 20rpx;
}

.nav-bar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back-btn {
  font-size: 48rpx;
  color: #1F2937;
  font-weight: 300;
}

.navbar-title {
  font-size: 36rpx;
  font-weight: 400;
  color: #1F2937;
}

.share-btn {
  font-size: 36rpx;
}

.content {
  flex: 1;
  padding: 24rpx;
}

.user-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
  display: block;
}

.post-time {
  font-size: 22rpx;
  color: #9CA3AF;
}

.follow-btn {
  padding: 10rpx 28rpx;
  background: #FF6B6B;
  color: #ffffff;
  border-radius: 50rpx;
  font-size: 24rpx;
}

.post-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  line-height: 1.5;
  display: block;
  margin-bottom: 20rpx;
}

.images-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rpx;
  margin-bottom: 20rpx;
}

.post-image {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 12rpx;
}

.post-content {
  font-size: 28rpx;
  color: #1F2937;
  line-height: 1.8;
  display: block;
  margin-bottom: 20rpx;
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.tag {
  font-size: 24rpx;
  color: #FF6B6B;
}

.action-bar {
  display: flex;
  gap: 48rpx;
  padding: 24rpx 0;
  border-top: 1rpx solid #F0EDE8;
  border-bottom: 1rpx solid #F0EDE8;
  margin-bottom: 24rpx;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.action-icon {
  font-size: 32rpx;
  color: #9CA3AF;
}

.action-icon.liked {
  color: #FF6B6B;
}

.action-count {
  font-size: 26rpx;
  color: #6B7280;
}

.comments-section {
  padding-bottom: 120rpx;
}

.comments-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
  display: block;
  margin-bottom: 20rpx;
}

.comment-item {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.comment-content {
  flex: 1;
}

.comment-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #1F2937;
  display: block;
}

.comment-text {
  font-size: 26rpx;
  color: #1F2937;
  display: block;
  margin-top: 4rpx;
}

.comment-time {
  font-size: 20rpx;
  color: #9CA3AF;
  display: block;
  margin-top: 6rpx;
}

.input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: #ffffff;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.04);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.input-field {
  flex: 1;
  background: #F5F0EB;
  padding: 16rpx 24rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
}

.send-btn {
  padding: 16rpx 32rpx;
  background: #FF6B6B;
  color: #ffffff;
  border-radius: 50rpx;
  font-size: 26rpx;
}
