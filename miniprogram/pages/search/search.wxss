/* 搜索页样式 */

.search-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFF9F5;
}

.nav-bar-placeholder {
  background: #FFF9F5;
  flex-shrink: 0;
  padding-left: 32rpx;
  padding-right: 32rpx;
  padding-bottom: 8rpx;
  margin-top: 20rpx;
}

.nav-bar-title {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.logo {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.logo-text {
  font-size: 36rpx;
  font-weight: 400;
  color: #1F2937;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 24rpx;
  margin-top: 24rpx;
  background: #FFF9F5;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #F5F0EB;
  padding: 16rpx 24rpx;
  border-radius: 50rpx;
}

.search-icon {
  font-size: 28rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
}

.cancel-btn {
  font-size: 28rpx;
  color: #6B7280;
}

.content {
  padding: 0 24rpx 24rpx 24rpx;
}

.section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
}

.clear-btn {
  font-size: 28rpx;
  color: #9CA3AF;
  margin-right: 50rpx;
}

.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  padding: 12rpx 24rpx;
  background: #ffffff;
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #1F2937;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
