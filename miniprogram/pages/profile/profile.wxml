<!--
  我的页面 - pages/profile/profile.wxml
  暖宠星球小程序 - 个人中心页
  支持登录状态展示
-->

<view class="profile-page">
  
  <!-- 自定义导航栏 - 固定顶部 -->
  <view 
    class="nav-bar-container"
    style="padding-top: {{statusBarHeight}}px;"
  >
    <view class="nav-bar-title" style="height: {{menuButtonHeight}}px;">
      <view class="logo">
        <text class="logo-text">我的星球</text>
      </view>
    </view>
  </view>

  <!-- 可滚动内容区域 -->
  <scroll-view class="main-content" scroll-y enable-back-to-top>

  <!-- 用户信息区 - 上移与首页搜索行齐平 -->
  <view class="profile-header" style="margin-top: 24rpx;">
    
    <!-- 已登录：用户卡片 -->
    <view class="user-card" wx:if="{{isLoggedIn}}">
      <view class="user-main">
        <view class="avatar-wrapper" bindtap="onChangeAvatar">
          <image class="avatar" src="{{userInfo.avatar || '/assets/images/avatar-default.png'}}" mode="aspectFill" />
          <view class="avatar-edit-hint">📷</view>
          <view class="vip-badge" wx:if="{{userInfo.isVip}}">⭐</view>
        </view>
        
        <view class="user-info">
          <view class="name-row">
            <text class="user-name">{{userInfo.name || '暖宠用户'}}</text>
            <view class="vip-icon" wx:if="{{userInfo.isVip}}">👑</view>
          </view>
          <text class="user-uid">UID: {{uid}} · {{userInfo.city || '未知'}}</text>
          <text class="user-bio">{{userInfo.bio || '暖宠星球萌主'}}</text>
        </view>
        
        <view class="edit-btn" bindtap="onEditTap">编辑</view>
      </view>
      
      <!-- VIP Banner -->
      <view class="vip-banner" bindtap="onVipTap">
        <view class="vip-left">
          <text class="vip-icon-text">👑</text>
          <view class="vip-text">
            <text class="vip-title">开通VIP会员</text>
            <text class="vip-desc">解锁更多特权</text>
          </view>
        </view>
        <view class="vip-right">
          <text class="vip-btn">立即开通</text>
        </view>
      </view>
      
      <!-- 数据统计 -->
      <view class="stats-row">
        <view class="stat-item">
          <text class="stat-value">{{stats.followers}}</text>
          <text class="stat-label">粉丝</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{stats.following}}</text>
          <text class="stat-label">关注</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{stats.likes}}</text>
          <text class="stat-label">获赞</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{stats.posts}}</text>
          <text class="stat-label">发布</text>
        </view>
      </view>
    </view>
    
    <!-- 未登录：游客卡片 -->
    <view class="guest-card" wx:else bindtap="onLoginTap">
      <view class="avatar-wrapper">
        <image class="avatar" src="{{guestInfo.avatar}}" mode="aspectFill" />
      </view>
      <view class="guest-info">
        <text class="guest-name">{{guestInfo.name}}</text>
        <text class="guest-bio">{{guestInfo.bio}}</text>
      </view>
    </view>
    
    <!-- 钱包入口 -->
    <view class="wallet-card">
      <view class="wallet-item">
        <text class="wallet-value">{{wallet.coins}}</text>
        <text class="wallet-label">萌币</text>
      </view>
      <view class="wallet-divider"></view>
      <view class="wallet-item">
        <text class="wallet-value">¥{{wallet.balance}}</text>
        <text class="wallet-label">余额</text>
      </view>
      <view class="wallet-divider"></view>
      <view class="wallet-item">
        <text class="wallet-value">{{wallet.messages}}</text>
        <text class="wallet-label">消息</text>
      </view>
    </view>
  </view>

  <!-- 菜单区域 -->
  <view class="menu-section">
    <!-- 我的发布/点赞/收藏/活动 -->
    <view class="menu-card">
      <block wx:for="{{menuList1}}" wx:key="id">
        <view 
          class="menu-item"
          data-item="{{item}}"
          bindtap="onMenuTap"
        >
          <view class="menu-icon" style="background:{{item.bg}}">
            <text>{{item.icon}}</text>
          </view>
          <view class="menu-info">
            <text class="menu-name">{{item.name}}</text>
            <text class="menu-count" wx:if="{{item.count}}">{{item.count}}</text>
          </view>
          <text class="menu-arrow">›</text>
        </view>
      </block>
    </view>

    <!-- 宠物管理/健康档案/订单/钱包 -->
    <view class="menu-card">
      <block wx:for="{{menuList2}}" wx:key="id">
        <view 
          class="menu-item"
          data-item="{{item}}"
          bindtap="onMenuTap"
        >
          <view class="menu-icon" style="background:{{item.bg}}">
            <text>{{item.icon}}</text>
          </view>
          <view class="menu-info">
            <text class="menu-name">{{item.name}}</text>
          </view>
          <text class="menu-arrow">›</text>
        </view>
      </block>
    </view>

    <!-- 帮助/关于/客服 -->
    <view class="menu-card">
      <block wx:for="{{menuList3}}" wx:key="id">
        <view 
          class="menu-item"
          data-item="{{item}}"
          bindtap="onMenuTap"
        >
          <view class="menu-icon" style="background:{{item.bg}}">
            <text>{{item.icon}}</text>
          </view>
          <view class="menu-info">
            <text class="menu-name">{{item.name}}</text>
          </view>
          <text class="menu-arrow">›</text>
        </view>
      </block>
    </view>

    <!-- 退出登录按钮 -->
    <view class="logout-section" wx:if="{{isLoggedIn}}">
      <view class="logout-btn" bindtap="onLogout">
        <text class="logout-text">退出登录</text>
      </view>
    </view>
  </view>

  <!-- 底部留白 -->
  <view class="bottom-space"></view>

  </scroll-view>

  <!-- 编辑资料弹窗 -->
  <view class="edit-modal-mask" wx:if="{{showEditModal}}" bindtap="onCloseEditModal">
    <view class="edit-modal" catchtap="onPreventBubble">
      <view class="edit-modal-header">
        <text class="edit-modal-title">编辑资料</text>
        <text class="edit-modal-close" bindtap="onCloseEditModal">✕</text>
      </view>

      <!-- 昵称 -->
      <view class="edit-field">
        <text class="edit-label">昵称</text>
        <input 
          class="edit-input" 
          value="{{editForm.nickname}}" 
          bindinput="onNicknameInput" 
          placeholder="请输入昵称" 
          maxlength="20"
        />
      </view>

      <!-- 手机号 -->
      <view class="edit-field">
        <text class="edit-label">手机号</text>
        <view class="edit-phone-row">
          <input 
            class="edit-input edit-phone-input" 
            value="{{editForm.phone}}" 
            bindinput="onPhoneInput" 
            placeholder="请输入手机号" 
            type="number"
            maxlength="11"
          />
          <view 
            class="edit-code-btn {{codeCountdown > 0 ? 'disabled' : ''}}" 
            bindtap="onSendCode"
          >
            <text>{{codeCountdown > 0 ? codeCountdown + 's' : '获取验证码'}}</text>
          </view>
        </view>
      </view>

      <!-- 验证码 -->
      <view class="edit-field" wx:if="{{editForm.phone.length === 11}}">
        <text class="edit-label">验证码</text>
        <input 
          class="edit-input" 
          value="{{editForm.code}}" 
          bindinput="onCodeInput" 
          placeholder="请输入验证码" 
          type="number"
          maxlength="6"
        />
      </view>

      <!-- 收件地址 -->
      <view class="edit-field">
        <text class="edit-label">收件地址</text>
        <textarea 
          class="edit-textarea" 
          value="{{editForm.address}}" 
          bindinput="onAddressInput" 
          placeholder="请输入收件地址" 
          maxlength="200"
          auto-height
        />
      </view>

      <!-- 保存按钮 -->
      <view class="edit-save-btn" bindtap="onSaveEdit">
        <text class="edit-save-text">保存</text>
      </view>
    </view>
  </view>
</view>
