<!--
  登录页面 - pages/login/login.wxml
  暖宠星球小程序 - 微信一键登录
-->

<view class="login-page">
  <!-- 自定义导航栏 -->
  <view 
    class="nav-bar-container"
    style="height: {{navBarHeight}}px; padding-top: {{statusBarHeight}}px;"
  >
    <view class="nav-bar-content" style="height: {{menuButtonHeight}}px;">
      <view class="nav-back" bindtap="onSkip">
        <text class="back-icon">✕</text>
      </view>
    </view>
  </view>

  <!-- Logo 区域 -->
  <view class="logo-section">
    <view class="logo-icon">
      <text class="logo-emoji">🐾</text>
    </view>
    <view class="app-name">暖宠星球</view>
    <view class="slogan">每一只宠物都是温暖的小星星</view>
  </view>

  <!-- 登录按钮区域 -->
  <view class="login-section">
    <!-- 微信一键登录 -->
    <view 
      class="login-btn primary {{loading ? 'loading' : ''}}"
      bindtap="doWechatLogin"
    >
      <block wx:if="{{!loading}}">
        <view class="wechat-icon-wrap">
          <text class="wechat-icon">💚</text>
        </view>
        <text class="btn-text">微信一键登录</text>
      </block>
      <block wx:else>
        <view class="loading-spinner"></view>
        <text class="btn-text">登录中...</text>
      </block>
    </view>

    <!-- 手机号登录 -->
    <view class="login-btn secondary" bindtap="goPhoneLogin">
      <text class="phone-icon">📱</text>
      <text class="btn-text-secondary">手机号登录</text>
    </view>
  </view>

  <!-- 隐私协议 -->
  <view class="privacy-section">
    <view class="privacy-check" bindtap="togglePrivacy">
      <view class="checkbox {{privacyChecked ? 'checked' : ''}}">
        <text wx:if="{{privacyChecked}}" class="check-mark">✓</text>
      </view>
      <text class="privacy-text">我已阅读并同意</text>
    </view>
    <view class="privacy-links">
      <text class="link" bindtap="onViewPrivacy">《隐私政策》</text>
      <text class="and">和</text>
      <text class="link" bindtap="onViewAgreement">《用户协议》</text>
    </view>
  </view>

  <!-- 跳过登录 -->
  <view class="skip-section">
    <text class="skip-btn" bindtap="onSkip">暂时跳过</text>
  </view>
</view>
