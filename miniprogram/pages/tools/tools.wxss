/* 平台页样式 - pages/tools/tools.wxss */

/* ===================== 页面基础 ===================== */

.tools-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFF9F5;
}

/* ===================== 自定义导航栏 ===================== */

.nav-bar-container {
  background: #FFF9F5;
  flex-shrink: 0;
  padding-left: 32rpx;
  padding-right: 32rpx;
  padding-bottom: 12rpx;
  margin-top: 20rpx;
}

.nav-bar-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.logo {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.logo-icon {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8EC4);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.logo-text {
  font-size: 36rpx;
  font-weight: 400;
  color: #1F2937;
}

.subtitle {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}

.version-tag {
  font-size: 20rpx;
  color: #9CA3AF;
  background: #F5F0EB;
  padding: 6rpx 16rpx;
  border-radius: 50rpx;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #F5F0EB;
  padding: 20rpx 24rpx;
  border-radius: 50rpx;
  margin: 24rpx 24rpx 0 24rpx;
}

.search-icon {
  font-size: 28rpx;
}

.search-placeholder {
  font-size: 26rpx;
  color: #9CA3AF;
}

/* ===================== 主内容区域 ===================== */

.content {
  flex: 1;
  height: 0;
}

/* ===================== 区块样式 ===================== */

.section {
  padding: 32rpx 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.section-accent {
  width: 8rpx;
  height: 32rpx;
  border-radius: 4rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
}

/* ===================== 核心工具 ===================== */

.tools-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.tool-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.tool-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
}

.tool-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tool-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.tool-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #222;
}

.tool-badge {
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border-radius: 50rpx;
}

.tool-desc {
  font-size: 24rpx;
  color: #9CA3AF;
}

.tool-usage {
  font-size: 22rpx;
  color: #FF6B6B;
}

.tool-arrow {
  font-size: 40rpx;
  color: #D1D5DB;
}

/* ===================== 本地服务 ===================== */

.services-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.service-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.service-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.service-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.service-name-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.service-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #222;
}

.service-badge {
  font-size: 18rpx;
  color: #FF6B6B;
  background: #FFF0F0;
  padding: 4rpx 10rpx;
  border-radius: 50rpx;
}

.service-desc {
  font-size: 22rpx;
  color: #9CA3AF;
}

/* ===================== 养宠知识 ===================== */

.knowledge-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.knowledge-item {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.knowledge-icon {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #FFF5F5, #FFF0F8);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.knowledge-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.knowledge-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #222;
}

.knowledge-desc {
  font-size: 24rpx;
  color: #9CA3AF;
}

.knowledge-arrow {
  font-size: 40rpx;
  color: #D1D5DB;
}

/* ===================== 底部留白 ===================== */

.bottom-space {
  height: 200rpx;
}
